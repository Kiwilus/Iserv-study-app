# studylearn.kv

# ScreenManager wird im Python-Code erstellt → Transition nicht hier definieren

# ─────────────────────────────────────────────
# Login Screen
# ─────────────────────────────────────────────
<LoginScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(40)
        spacing: dp(25)

        #Image:
            #source: 'iserv_logo.png'   # Optional
            #size_hint_y: None
            #height: dp(90)
            #allow_stretch: True
            #keep_ratio: True

        Label:
            text: "IServ Dashboard"
            font_size: "28sp"
            bold: True
            color: 0.18, 0.48, 0.9, 1
            size_hint_y: None
            height: dp(60)

        Widget:
            size_hint_y: None
            height: dp(10)

        TextInput:
            id: url_input
            hint_text: "IServ URL (z.B. https://schule.iserv.de)"
            multiline: False
            size_hint_y: None
            height: dp(52)
            font_size: "16sp"
            padding: dp(12), dp(12)

        TextInput:
            id: username_input
            hint_text: "Benutzername"
            multiline: False
            size_hint_y: None
            height: dp(52)
            font_size: "16sp"
            padding: dp(12), dp(12)

        TextInput:
            id: password_input
            hint_text: "Passwort"
            password: True
            multiline: False
            size_hint_y: None
            height: dp(52)
            font_size: "16sp"
            padding: dp(12), dp(12)

        Button:
            text: "Anmelden"
            size_hint_y: None
            height: dp(56)
            font_size: "18sp"
            background_color: 0.18, 0.48, 0.9, 1
            color: 1, 1, 1, 1
            on_release: root.login()

        Label:
            text: root.error_text
            color: 0.92, 0.35, 0.35, 1
            size_hint_y: None
            height: dp(35)
            halign: "center"
            text_size: self.width, None
            font_size: "15sp"


# ─────────────────────────────────────────────
# Loading Screen
# ─────────────────────────────────────────────
<LoadingScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(40)
        spacing: dp(30)

        Widget:
            size_hint_y: 0.35

        Spinner:
            size_hint: None, None
            size: dp(70), dp(70)
            pos_hint: {'center_x': 0.5}
            active: True

        Label:
            text: root.status_text
            font_size: "19sp"
            halign: "center"
            color: 0.75, 0.78, 0.85, 1

        Widget:
            size_hint_y: 0.65


# ─────────────────────────────────────────────
# Main Screen
# ─────────────────────────────────────────────
<MainScreen>:
    BoxLayout:
        orientation: 'vertical'

        # Header
        BoxLayout:
            size_hint_y: None
            height: dp(72)
            padding: dp(16)
            spacing: dp(12)
            canvas.before:
                Color:
                    rgba: 0.12, 0.15, 0.22, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Label:
                text: "Willkommen, " + root.username_label
                font_size: "20sp"
                bold: True
                color: 1, 1, 1, 1
                size_hint_x: 0.6
                halign: "left"

            Button:
                text: "Aktualisieren"
                size_hint_x: 0.2
                background_color: 0.22, 0.58, 1, 1
                on_release: root.refresh()

            Button:
                text: "Abmelden"
                size_hint_x: 0.2
                background_color: 0.75, 0.25, 0.25, 1
                on_release: root.logout()

        # Statuszeile
        Label:
            text: root.is_loading if root.is_loading else root.status_text
            size_hint_y: None
            height: dp(34)
            font_size: "14sp"
            color: 0.65, 0.72, 0.88, 1
            padding: dp(16), 0

        ScrollView:
            do_scroll_x: False
            bar_width: dp(9)
            bar_color: 0.3, 0.5, 0.9, 0.75

            BoxLayout:
                orientation: 'vertical'
                padding: dp(16)
                spacing: dp(26)
                size_hint_y: None
                height: self.minimum_height

                # E-Mails
                BoxLayout:
                    size_hint_y: None
                    height: dp(68)
                    spacing: dp(15)

                    Label:
                        text: "E-Mails"
                        font_size: "18sp"
                        bold: True
                        size_hint_x: None
                        width: dp(130)
                        color: 0.95, 0.95, 1, 1

                    Label:
                        text: str(root.unread_count) + " ungelesen"
                        font_size: "23sp"
                        bold: True
                        color: (0.18, 0.48, 0.9, 1) if root.unread_count > 0 else (0.6, 0.7, 0.8, 1)

                # Aktive Aufgaben
                Label:
                    text: "Aktive Aufgaben"
                    font_size: "19sp"
                    bold: True
                    color: 0.95, 0.95, 1, 1
                    size_hint_y: None
                    height: dp(36)

                TaskList:
                    tasks: root.active_tasks
                    accent_color: 0.18, 0.65, 0.35, 1

                # Überfällige Aufgaben
                Label:
                    text: "Überfällige Aufgaben"
                    font_size: "19sp"
                    bold: True
                    color: 0.95, 0.4, 0.35, 1
                    size_hint_y: None
                    height: dp(36)

                TaskList:
                    tasks: root.overdue_tasks
                    accent_color: 0.9, 0.25, 0.25, 1

                # Sonstige Benachrichtigungen
                Label:
                    text: "Weitere Benachrichtigungen"
                    font_size: "19sp"
                    bold: True
                    color: 0.8, 0.82, 0.9, 1
                    size_hint_y: None
                    height: dp(36)

                NotifList:
                    notifs: root.other_notifs


# ─────────────────────────────────────────────
# Custom Widgets
# ─────────────────────────────────────────────

<TaskRow@BoxLayout>:
    title_text: ""
    date_text: ""
    msg_text: ""
    accent: [0.18, 0.48, 0.9, 1]

    orientation: "vertical"
    size_hint_y: None
    height: dp(94)
    padding: dp(15)
    spacing: dp(7)

    canvas.before:
        Color:
            rgba: 0.155, 0.17, 0.23, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(13)]

        Color:
            rgba: root.accent
        Rectangle:
            pos: self.x, self.y + self.height - dp(5)
            size: self.width, dp(5)

    Label:
        text: root.title_text
        font_size: "17sp"
        bold: True
        color: 0.96, 0.97, 1, 1
        size_hint_y: None
        height: dp(27)
        halign: "left"
        text_size: self.width - dp(8), None
        shorten: True
        shorten_from: "right"

    BoxLayout:
        size_hint_y: None
        height: dp(22)
        spacing: dp(10)

        Label:
            text: root.date_text
            font_size: "14sp"
            color: 0.55, 0.68, 0.9, 1
            halign: "left"

        Label:
            text: root.msg_text
            font_size: "14sp"
            color: 0.68, 0.72, 0.82, 1
            halign: "left"
            text_size: self.width, None
            shorten: True
            shorten_from: "right"