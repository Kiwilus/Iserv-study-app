ScreenManager:
    LoginScreen:
    LoadingScreen:
    MainScreen:


<LoginScreen>:
    name: "login"

    BoxLayout:
        orientation: "vertical"
        padding: 20
        spacing: 10

        Label:
            text: "Einloggen mit IServ Account..."

        TextInput:
            id: "URL"
            hint_text: "URL von deinem IServ"
            multi_line: False

        TextInput:
            id: "Username"
            hint_text: "dein Nutzername bitte"
            multi_line: False

        TextInput:
            id: "Password"
            hint_text: "und jetzt dein IServ passwort"
            multi_line: False

        Button:
            text: "Einloggen"
            on_press: root.login()


<LoadingScreen>:
    name: "loading"

    BoxLayout:
        orientation: "vertical"

        Label:
            text: "Verbinde..."

        Button:
            text: "Weiter"
            on_press: root.go_main()


<MainScreen>:
    name: "main"

    BoxLayout:
        orientation: "vertical"

        Label:
            text: "Du bist eingeloggt "